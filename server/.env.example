# Copy this file to ".env" and fill in the values as you create each account.
# Chelsey will come to life piece by piece as you add keys.

# ── Tavus — the live video avatar (her face) ───────────────────────────────
TAVUS_API_KEY=
# A replica id from your Tavus dashboard = the face Chelsey wears.
# Pick a stock replica to start (looks like "r79e1c033f").
TAVUS_REPLICA_ID=
# Optional: leave blank. A Chelsey persona is created automatically on first run
# and cached in server/.persona-id. Run "npm run reset-persona" after editing
# her personality to rebuild it.
TAVUS_PERSONA_ID=

# ── ElevenLabs — her voice ─────────────────────────────────────────────────
ELEVENLABS_API_KEY=
# A soft, feminine voice id from the ElevenLabs Voice Library.
ELEVENLABS_VOICE_ID=

# ── Anthropic — her brain (Claude) ─────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ── How Chelsey thinks ─────────────────────────────────────────────────────
# true  = Tavus talks to OUR Claude proxy, so Chelsey's authentic personality
#         drives every reply. Requires this server to be reachable from the
#         internet: set PUBLIC_URL to an https tunnel (e.g. ngrok) pointing here.
# false = use Tavus's built-in LLM. Works instantly, but less "Chelsey".
USE_CLAUDE=true
# Public https URL where Tavus can reach THIS server, e.g. https://abc123.ngrok.app
PUBLIC_URL=

# ── Server ─────────────────────────────────────────────────────────────────
PORT=8787
# Comma-separated origins allowed to call this server (the web app).
CORS_ORIGINS=http://localhost:5173
